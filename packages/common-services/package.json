{
  "name": "@oasisbio/common-services",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "@oasisbio/common-core": "workspace:*",
    "@oasisbio/common-utils": "workspace:*",
    "@oasisbio/common-auth": "workspace:*",
    "@supabase/supabase-js": "^2.43.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5"
  }
}
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react",
    "declaration": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@oasisbio/common-core": ["../common-core/src"],
      "@oasisbio/common-utils": ["../common-utils/src"],
      "@oasisbio/common-auth": ["../common-auth/src"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../common-core" },
    { "path": "../common-utils" },
    { "path": "../common-auth" }
  ]
}
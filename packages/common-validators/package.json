{
  "name": "@oasisbio/common-validators",
  "version": "0.1.0",
  "description": "OasisBio Validation Rules & Validators",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "lint": "eslint src"
  },
  "keywords": ["oasisbio", "validation"],
  "author": "OasisBio Team",
  "license": "MIT",
  "dependencies": {
    "@oasisbio/common-core": "workspace:*",
    "@oasisbio/common-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsup": "^8.0.2",
    "typescript": "^5.4.3"
  }
}

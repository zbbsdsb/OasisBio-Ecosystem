{
  "name": "@oasisbio/common-core",
  "version": "0.1.0",
  "description": "OasisBio Core Types, Enums, and Constants",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.mjs",
      "require": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    },
    "./enums": {
      "import": "./dist/enums/index.mjs",
      "require": "./dist/enums/index.js",
      "types": "./dist/enums/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants/index.mjs",
      "require": "./dist/constants/index.js",
      "types": "./dist/constants/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/models/index.ts src/enums/index.ts src/constants/index.ts src/types/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/models/index.ts src/enums/index.ts src/constants/index.ts src/types/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "lint": "eslint src"
  },
  "keywords": ["oasisbio", "core", "types"],
  "author": "OasisBio Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsup": "^8.0.2",
    "typescript": "^5.4.3"
  }
}
